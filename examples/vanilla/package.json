{
  "name": "vanilla",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext js --config .eslintrc --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint src --ext js --config .eslintrc --report-unused-disable-directives --max-warnings 0 --fix",
    "lint:css": "pnpm exec stylelint \"src/**/*.scss\" --config .stylelintrc",
    "lint:css:fix": "pnpm exec stylelint \"src/**/*.scss\" --config .stylelintrc --fix"
  },
  "dependencies": {
    "simplex-noise": "4.0.3"
  },
  "devDependencies": {
    "@embyth/eslint-plugin": "0.4.0",
    "@embyth/prettier-config": "1.1.1",
    "@embyth/scss-design-system": "workspace:*",
    "@embyth/stylelint-config": "0.7.1",
    "eslint": "10.4.1",
    "prettier": "3.8.4",
    "stylelint": "17.13.0",
    "vite": "8.0.16"
  }
}
